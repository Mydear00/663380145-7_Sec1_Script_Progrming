Block A: Evaluation Check
--Code--
temp = 25
is_raining = True

if temp > 20 and not is_raining:
    print("Perfect day for a picnic!")
elif temp <= 20 or is_raining:
    print("Stay indoors or bring an umbrella.")
else:
    print("Unsure about the weather.")
----------------------------------------------------------------------------

    --ค่าที่กำหนด--

temp = 25
is_raining = True


--ลำดับการทำงาน--
ตรวจสอบ temp > 20 and not is_raining
25 > 20 → True
not True → False
True and False → False (ไม่เข้า if)
ตรวจสอบ temp <= 20 or is_raining
25 <= 20 → False
is_raining → True
False or True → True (เข้า elif)

--Output--
Stay indoors or bring an umbrella.
